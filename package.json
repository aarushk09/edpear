{
  "name": "edpear",
  "version": "2.0.0",
  "description": "EdPear is an edtech-focused component library with production-ready UI primitives and optional OpenRouter-powered teaching helpers.",
  "license": "MIT",
  "author": "EdPear",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "edpear": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/components",
    "src/lib/cn.ts",
    "src/lib/openrouter.ts",
    "src/lib/registry.ts",
    "styles/edpear.css",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openrouter": {
      "types": "./dist/lib/openrouter.d.ts",
      "import": "./dist/lib/openrouter.js"
    },
    "./styles.css": "./styles/edpear.css"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format:check": "prettier --check .",
    "dev": "npm run showcase:dev",
    "showcase:dev": "npm run dev --prefix showcase-next",
    "showcase:build": "npm run build --prefix showcase-next"
  },
  "keywords": [
    "edpear",
    "edtech",
    "design-system",
    "component-library",
    "tailwind",
    "react",
    "openrouter"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-python": "^6.1.8",
    "@tiptap/extension-placeholder": "^2.26.1",
    "@tiptap/react": "^2.26.1",
    "@tiptap/starter-kit": "^2.26.1",
    "@uiw/react-codemirror": "^4.25.2",
    "chalk": "^5.6.2",
    "clsx": "^2.1.1",
    "commander": "^14.0.1",
    "diff": "^8.0.3",
    "fs-extra": "^11.3.2",
    "katex": "^0.16.39",
    "lucide-react": "^0.542.0",
    "ora": "^8.2.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.5"
  }
}
