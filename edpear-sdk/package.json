{
  "name": "edpear-sdk",
  "version": "2.0.0",
  "description": "EdPear SDK — React component library for edtech (publish alias; same bits as the edpear package).",
  "license": "MIT",
  "author": "EdPear",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "edpear": "dist/cli.js",
    "edpear-sdk": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/components",
    "src/lib/cn.ts",
    "src/lib/openrouter.ts",
    "src/lib/registry.ts",
    "styles/edpear.css",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openrouter": {
      "types": "./dist/lib/openrouter.d.ts",
      "import": "./dist/lib/openrouter.js"
    },
    "./styles.css": "./styles/edpear.css"
  },
  "scripts": {
    "sync": "node ./scripts/sync-from-root.mjs",
    "prepack": "npm run sync",
    "prepublishOnly": "npm run sync"
  },
  "keywords": [
    "edpear",
    "edpear-sdk",
    "edtech",
    "design-system",
    "component-library",
    "tailwind",
    "react",
    "openrouter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aarushk09/edpear.git",
    "directory": "edpear-sdk"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-python": "^6.1.8",
    "@tiptap/extension-placeholder": "^2.26.1",
    "@tiptap/react": "^2.26.1",
    "@tiptap/starter-kit": "^2.26.1",
    "@uiw/react-codemirror": "^4.25.2",
    "chalk": "^5.6.2",
    "clsx": "^2.1.1",
    "commander": "^14.0.1",
    "diff": "^8.0.3",
    "fs-extra": "^11.3.2",
    "katex": "^0.16.39",
    "lucide-react": "^0.542.0",
    "ora": "^8.2.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  }
}
